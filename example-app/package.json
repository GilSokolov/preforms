{
  "name": "example-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run sync:examples && ng serve",
    "build": "npm run sync:examples && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "sync:examples": "node scripts/copy-to-txt.js",
    "serve:ssr:example-app": "node dist/example-app/server/server.mjs",
    "deploy:docs": "npx angular-cli-ghpages --dir=dist/example-app/browser"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@angular/cdk": "^21.1.4",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/material": "^21.1.5",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-server": "^21.1.0",
    "@angular/router": "^21.2.6",
    "@angular/ssr": "^21.1.3",
    "express": "^5.1.0",
    "marked": "^17.0.0",
    "ngx-markdown": "^21.1.0",
    "ngx-quill": "^30.0.1",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.30.0",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.4",
    "@angular/cli": "^21.2.4",
    "@angular/compiler-cli": "^21.2.6",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "gh-pages": "^6.3.0",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}