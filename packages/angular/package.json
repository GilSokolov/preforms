    "@angular/common": ">=21 <22",
    "@angular/forms": ">=21 <22",
    "@angular/cdk": ">=21 <22",
    "@angular/material": ">=21 <22",
    "@preforms/ts": "^0.1.0",
    "rxjs": "^7.8.0"
  },
