{
  "name": "@preforms/ts",
  "version": "0.1.0",
  "description": "TypeScript models, fields, schemas, and trigger utilities for Preforms.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fields": {
      "types": "./dist/fields/index.d.ts",
      "import": "./dist/fields/index.js",
      "require": "./dist/fields/index.cjs"
    },
    "./buttons": {
      "types": "./dist/buttons/index.d.ts",
      "import": "./dist/buttons/index.js",
      "require": "./dist/buttons/index.cjs"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.js",
      "require": "./dist/layout/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "forms",
    "dynamic-forms",
    "schema",
    "typescript"
  ],
  "author": "Gil Sokolov",
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts src/fields/index.ts src/buttons/index.ts src/layout/index.ts --format esm,cjs --dts",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^6.7.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
